MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=car_bti

NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_OUTPUT_TOKENS=2048
OPENAI_MIN_REQUEST_INTERVAL=0.5
OPENAI_MAX_RETRIES=3
OPENAI_MAX_CONTINUATIONS=2

# 1=의미 기반 FAQ 검색 활성화
OPENAI_FAQ_EMBEDDING=1

# 임베딩 제공자: auto | openai | local
# OpenAI 할당량 부족(429 insufficient_quota) 시 local 권장
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
LOCAL_EMBEDDING_BATCH_SIZE=32
OPENAI_EMBEDDING_BATCH_SIZE=16

# Vector DB 저장 경로
VECTOR_DB_PATH=data/chroma

# 하이브리드 검색 가중치 (semantic + keyword + company)
FAQ_SEMANTIC_WEIGHT=0.55
FAQ_KEYWORD_WEIGHT=0.30
FAQ_COMPANY_WEIGHT=0.15
FAQ_MIN_HYBRID_SCORE=0.12
FAQ_MIN_KEYWORD_SCORE=0.15
