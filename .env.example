MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=car_bti

NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# AI 상담 챗봇 (Google Gemini - 무료 티어)
# 키가 없어도 챗봇은 '기본 모드'로 동작하지만,
# 키를 설정하면 자연스러운 대화형 답변(AI 모드)이 켜집니다.
# 키 발급: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key
# (선택) 모델 변경 시
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
GEMINI_MAX_OUTPUT_TOKENS=1024
# 무료 티어 429 완화: API 호출 최소 간격(초), 재시도 횟수
GEMINI_MIN_REQUEST_INTERVAL=2
GEMINI_MAX_RETRIES=3
# FAQ 임베딩 검색 (1=켜기, 기본 0=키워드 검색만 → API 호출 절약)
GEMINI_FAQ_EMBEDDING=0
# FAQ 검색 최소 점수 (이하이면 관련 없음 처리)
FAQ_MIN_KEYWORD_SCORE=0.9
FAQ_MIN_EMBED_SCORE=0.55